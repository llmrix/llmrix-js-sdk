{
  "name": "llmrix-js-sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the llmrix AI Agent Platform",
  "author": "Llmrix",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/llmrix/llmrix-js-sdk.git"
  },
  "homepage": "https://www.llmrix.com/",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && tsc -p tsconfig.types.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:types": "tsc -p tsconfig.types.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "llmrix",
    "ai",
    "agent",
    "sdk",
    "sse",
    "streaming"
  ]
}